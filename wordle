#!/usr/bin/env uv run --script
import re
import sys

def parse_guess(guess):
    pattern = []
    include = set()
    exclude = set()
    
    i = 0
    while i < len(guess) and len(pattern) < 5:
        if guess[i] in '+-':
            # Marker before letter
            marker = guess[i]
            if i + 1 < len(guess):
                letter = guess[i + 1]
                if marker == '+':
                    pattern.append(letter)
                else:  # marker == '-'
                    pattern.append(f'[^{letter}]')
                include.add(letter)
                i += 2
            else:
                i += 1
        else:
            # No marker - excluded letter
            pattern.append('.')
            exclude.add(guess[i])
            i += 1
    
    # Pad to 5 positions if needed
    while len(pattern) < 5:
        pattern.append('.')
    
    return pattern, include, exclude

def find_words(pattern, include, exclude):
    with open('/usr/share/dict/words') as f:
        words = [w.strip().lower() for w in f if len(w.strip()) == 5 and w.strip().isalpha() and w.strip().islower()]
    
    regex = re.compile(f'^{pattern}$')
    matches = [w for w in words if regex.match(w)]
    
    if include:
        matches = [w for w in matches if all(c in w for c in include)]
    if exclude:
        matches = [w for w in matches if not any(c in w for c in exclude)]
    
    return matches

print("Wordle Helper - Enter guesses like: ad+ie-u")
print("(+letter = correct position, -letter = wrong position, letter = not in word)")
print()

all_exclude = set()
all_include = set()
patterns = ['.'] * 5

while True:
    guess = input("Guess result (/q to quit): ").strip().lower()
    if not guess or guess == '/q':
        break
    
    pattern, include, exclude = parse_guess(guess)
    
    # Merge pattern constraints
    for i, c in enumerate(pattern):
        if c != '.':
            if c.startswith('[^'):
                # Negative constraint - merge with existing
                if patterns[i] == '.':
                    patterns[i] = c
                elif patterns[i].startswith('[^'):
                    # Merge multiple negative constraints
                    existing = patterns[i][2:-1]
                    new_char = c[2:-1]
                    patterns[i] = f'[^{existing}{new_char}]'
            else:
                # Positive constraint - overwrite
                patterns[i] = c
    
    all_include.update(include)
    all_exclude.update(exclude)
    
    final_pattern = ''.join(patterns)
    words = find_words(final_pattern, all_include, all_exclude)
    
    print(f"\nPattern: {final_pattern}")
    print(f"Must include: {sorted(all_include)}")
    print(f"Must exclude: {sorted(all_exclude)}")
    print(f"\nPossible words ({len(words)}):")
    for w in words:
        print(w)
    print()
